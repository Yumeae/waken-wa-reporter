{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Waken-Wa Reporter",
  "version": "0.1.0",
  "identifier": "com.waken-wa.reporter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Waken-Wa Reporter",
        "width": 360,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "Waken-Wa Reporter",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
